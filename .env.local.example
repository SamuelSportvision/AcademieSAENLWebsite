# Resend — for the contact form. Get your key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here

# Supabase — copy this file to .env.local and fill in your values.
# Get these from your Supabase project dashboard → Settings → API.
# None of these keys are ever sent to the browser.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
